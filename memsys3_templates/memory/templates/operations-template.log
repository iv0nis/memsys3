# version: 0.1.0
# Operations Log Template
# Registro automático de operaciones del sistema (actualizar, compilar)
#
# Formato: YAML append-only, orden cronológico inverso (más reciente primero)
# Rotación: cuando >= 1800 líneas, rotar a operations_N.log (estilo sessions)
# Archivos rotados se pueden borrar libremente (no hay archivado, no se leen)
# Este archivo NO se lee en newSession ni compile-context — solo consulta bajo demanda
# Origen: FEATURE-009. Schema canonizado en ADR-024 (criterio data-vs-as-is).

# ============================================
# CAMPOS
# ============================================
# - timestamp: ISO 8601 (YYYY-MM-DDTHH:MM:SS)
# - operacion: "actualizar" | "compilar"
# - resultado: "ok" | "warn" | "fail"
# - Para "actualizar": version_origen, version_destino (memsys3_version)
# - Para "compilar":   version_context (versión de context.yaml generada)
# - resumen: objeto libre con métricas/notas relevantes a la operación

# ============================================
# EJEMPLOS (descomentar y adaptar al añadir entradas)
# ============================================

# operations:
#   - timestamp: "2026-05-07T14:32:00"
#     operacion: "compilar"
#     version_context: "0.13.0"
#     resultado: "ok"
#     resumen:
#       lineas: 609
#       adrs_incluidas: "13 de 14"
#       sesiones_incluidas: "10 (5 alto, 3 medio, 2 bajo)"
#       gotchas: "8 críticos"
#       reduccion_tokens: "~95%"
#       archivamiento: "no activado"
#
#   - timestamp: "2026-05-07T10:15:00"
#     operacion: "actualizar"
#     version_origen: "0.22.0"
#     version_destino: "0.23.0"
#     resultado: "ok"
#     resumen:
#       archivos_actualizados: 3
#       archivos_custom_preservados: 0
#       backups_creados: "memsys3_backup_20260507_101500/"

# ============================================
# ESTADO INICIAL (vacío)
# ============================================

operations: []
